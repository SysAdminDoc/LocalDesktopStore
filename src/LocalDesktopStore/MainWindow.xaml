<Window x:Class="LocalDesktopStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LocalDesktopStore.ViewModels"
        xmlns:views="clr-namespace:LocalDesktopStore.Views"
        xmlns:conv="clr-namespace:LocalDesktopStore.Converters"
        Title="LocalDesktopStore" Height="820" Width="1280"
        MinWidth="920" MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVis" />
    </Window.Resources>

    <Grid Background="{StaticResource BaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="168" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CrustBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,0,1"
                Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="44"
                        Height="44"
                        CornerRadius="8"
                        Background="{StaticResource MauveSoftBrush}"
                        BorderBrush="{StaticResource MauveBrush}"
                        BorderThickness="1"
                        Margin="0,0,14,0">
                    <TextBlock Text="LDS"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MauveBrush}" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="LocalDesktopStore" Style="{StaticResource HeadingText}" />
                    <TextBlock Text="A private catalog for Windows desktop apps built from your GitHub releases."
                               Style="{StaticResource SubtleText}" />
                    <TextBlock Style="{StaticResource MuteText}" Margin="0,3,0,0">
                        <Run Text="{Binding AvailableCount, Mode=OneWay}" />
                        <Run Text=" available" />
                        <Run Text=" / " Foreground="{StaticResource MuteBrush}" />
                        <Run Text="{Binding InstalledCount, Mode=OneWay}" Foreground="{StaticResource GreenBrush}" />
                        <Run Text=" installed" />
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource MantleBrush}"
                Padding="20,12"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Width="470" MinWidth="320">
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Search apps, repositories, or descriptions"
                                   Style="{StaticResource MuteText}"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource EmptyStringToVis}}" />
                    </Grid>

                    <CheckBox Grid.Column="2"
                              Content="Installed only"
                              IsChecked="{Binding ShowInstalledOnly}"
                              VerticalAlignment="Center"
                              Margin="18,0" />

                    <Button Grid.Column="4"
                            Content="Install folder"
                            Command="{Binding OpenInstallDirCommand}"
                            Margin="0,0,8,0" />

                    <Button Grid.Column="5"
                            Content="{Binding RefreshButtonLabel}"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0" />

                    <Button Grid.Column="6"
                            Content="Settings"
                            x:Name="SettingsToggleButton"
                            Click="ToggleSettings_Click" />
                </Grid>

                <ProgressBar Grid.Row="1"
                             IsIndeterminate="True"
                             Margin="0,10,0,0"
                             Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <Border x:Name="SettingsDrawer"
                Grid.Row="2"
                Style="{StaticResource PanelBorder}"
                Margin="20,14,20,0"
                Padding="18"
                Visibility="Collapsed"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Discovery settings" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Configure the GitHub source, topic filter, hash verification, and rate-limit token."
                                   Style="{StaticResource SubtleText}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Close"
                            Click="ToggleSettings_Click"
                            Style="{StaticResource LinkButton}"
                            VerticalAlignment="Top" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="GitHub user or organization" Style="{StaticResource InputLabel}" />
                        <Grid>
                            <TextBox x:Name="GitHubUserBox"
                                     Text="{Binding GitHubUserInput, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="example: SysAdminDoc"
                                       Style="{StaticResource MuteText}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=GitHubUserBox, Converter={StaticResource EmptyStringToVis}}" />
                        </Grid>

                        <TextBlock Text="GitHub personal access token"
                                   Style="{StaticResource InputLabel}"
                                   Margin="0,12,0,5" />
                        <PasswordBox x:Name="GitHubTokenBox"
                                     PasswordChanged="GitHubTokenBox_PasswordChanged" />
                        <TextBlock Text="Optional. Stored only in your local settings file; leave blank to use public GitHub rate limits."
                                   Style="{StaticResource MuteText}"
                                   TextWrapping="Wrap"
                                   Margin="0,7,0,0" />

                        <TextBlock Text="Install folder override"
                                   Style="{StaticResource InputLabel}"
                                   Margin="0,12,0,5" />
                        <Grid>
                            <TextBox x:Name="InstallRootBox"
                                     Text="{Binding InstallRootOverride, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="(default %LOCALAPPDATA%\LocalDesktopStore\apps)"
                                       Style="{StaticResource MuteText}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=InstallRootBox, Converter={StaticResource EmptyStringToVis}}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <CheckBox Content="Filter by GitHub topic"
                                  IsChecked="{Binding UseTopicFilter}" />
                        <Grid Margin="0,8,0,0">
                            <TextBox x:Name="TopicFilterBox"
                                     Text="{Binding TopicFilter, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding UseTopicFilter}" />
                            <TextBlock Text="windows-app"
                                       Style="{StaticResource MuteText}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=TopicFilterBox, Converter={StaticResource EmptyStringToVis}}" />
                        </Grid>
                        <TextBlock Style="{StaticResource MuteText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Text="When enabled, discovery only shows repos tagged with the selected topic. Otherwise any repo whose latest release ships an MSI / EXE / ZIP can appear." />

                        <CheckBox Content="Verify SHA-256 sidecar"
                                  IsChecked="{Binding VerifyHashSidecar}"
                                  Margin="0,16,0,0" />
                        <TextBlock Style="{StaticResource MuteText}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Text="When enabled, every install verifies the asset against its `.sha256.txt` sidecar before invoking the installer. Refuses to install on mismatch." />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                MinWidth="170"
                                VerticalAlignment="Bottom">
                        <Button Content="Save and refresh"
                                Command="{Binding SaveAndRefreshCommand}"
                                Style="{StaticResource AccentButton}"
                                Margin="0,0,0,8" />
                        <Button Content="Save settings"
                                Command="{Binding SaveSettingsCommand}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,14,12,16">
                <ItemsControl ItemsSource="{Binding AppsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:AppCardView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="520"
                    Padding="24"
                    Style="{StaticResource PanelBorder}"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateTitle}"
                               Style="{StaticResource SectionTitle}"
                               TextAlignment="Center" />
                    <TextBlock Text="{Binding EmptyStateMessage}"
                               Style="{StaticResource SubtleText}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,8,0,18" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Refresh catalog"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource AccentButton}"
                                Margin="0,0,8,0" />
                        <Button Content="Open settings"
                                Click="ToggleSettings_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="{StaticResource MantleBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,8,0,8" VerticalAlignment="Center">
                    <TextBlock Text="Activity log" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Download, install, run, and error events"
                               Style="{StaticResource MuteText}"
                               Margin="10,1,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Clear"
                        Command="{Binding ClearLogCommand}"
                        Style="{StaticResource LinkButton}"
                        Margin="0,0,16,0" />
            </Grid>
        </Border>

        <Border Grid.Row="5" Background="{StaticResource CrustBrush}" Padding="16,10">
            <ListBox ItemsSource="{Binding LogLines}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="11"
                     Foreground="{StaticResource SubtextBrush}"
                     x:Name="LogList">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="0,1" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <Border Grid.Row="6"
                Background="{StaticResource CrustBrush}"
                Padding="16,7"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Style="{StaticResource SubtleText}" />
                <TextBlock Grid.Column="1" Style="{StaticResource MuteText}">
                    <Run Text="LocalDesktopStore v0.2.0-alpha" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
